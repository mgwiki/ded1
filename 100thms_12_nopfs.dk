 := (A : Elem set => (B : Elem set => (All set (x => (Imp ((In x) A) ((In x) B)))))).
set_ext : pf (All set (X => (All set (Y => (Imp ((Subq X) Y) (Imp ((Subq Y) X) (((eq set) X) Y))))))).
In_ind : pf (All (arr set prop) (P => (Imp (All set (X => (Imp (All set (x => (Imp ((In x) X) (P x)))) (P X)))) (All set (X => (P X)))))).
