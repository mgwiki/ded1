type : Type.
arr : type -> type -> type.
def Elem : type -> Type.
[a,b] Elem (arr a b) --> Elem a -> Elem b.

set : type.
prop : type.
def pf : Elem prop -> Type.

def Ap : (a:type) -> (b:type) -> Elem (arr a b) -> Elem a -> Elem b.
def Lam : (a:type) -> (b:type) -> (Elem a -> Elem b) -> Elem (arr a b).
Imp : Elem prop -> Elem prop -> Elem prop.
All : (a:type) -> (Elem a -> Elem prop) -> Elem prop.

[a,b,m,n] Ap a b (Lam a b m n) --> m n. (; beta ;)
[a,b,m,n] Lam a b (Ap a b m) --> m. (; eta ;)

[p,q] pf (Imp p q) --> pf p -> pf q.
[a,p] pf (All a p) --> (x:Elem a) -> pf (p x).
Eps_i : Elem (arr (arr set prop) set).
Eps_i_ax : pf (All (arr set prop) (P => (All set (x => (Imp (P x) (P (Eps_i P))))))).
def True :  Elem prop
 := (All prop (p => (Imp p p))).
def False :  Elem prop
 := (All prop (p => p)).
def not :  Elem (arr prop prop)
 := (A : Elem prop => (Imp A False)).
def and :  Elem (arr prop (arr prop prop))
 := (A : Elem prop => (B : Elem prop => (All prop (p => (Imp (Imp A (Imp B p)) p))))).
def or :  Elem (arr prop (arr prop prop))
 := (A : Elem prop => (B : Elem prop => (All prop (p => (Imp (Imp A p) (Imp (Imp B p) p)))))).
def iff :  Elem (arr prop (arr prop prop))
 := (A : Elem prop => (B : Elem prop => ((and (Imp A B)) (Imp B A)))).
def eq : (a:type) ->  Elem (arr a (arr a prop))
 := (a => (x : Elem a => (y : Elem a => (All (arr a (arr a prop)) (Q => (Imp ((Q x) y) ((Q y) x))))))).
def neq : (a:type) ->  Elem (arr a (arr a prop))
 := (a => (x : Elem a => (y : Elem a => (not (((eq a) x) y))))).
func_ext : (a:type) -> (b:type) -> pf (All (arr a b) (f => (All (arr a b) (g => (Imp (All a (x => (((eq b) (f x)) (g x)))) (((eq (arr a b)) f) g)))))).
def ex : (a:type) ->  Elem (arr (arr a prop) prop)
 := (a => (Q : Elem (arr a prop) => (All prop (P => (Imp (All a (x => (Imp (Q x) P))) P))))).
prop_ext : pf (All prop (p => (All prop (q => (Imp ((iff p) q) (((eq prop) p) q)))))).
