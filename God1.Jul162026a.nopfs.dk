 := (U : Elem set => (All set (X => (Imp ((In X) U) (All (arr set set) (F => (Imp (All set (x => (Imp ((In x) X) ((In (F x)) U)))) ((In ((Repl X) (x : Elem set => (F x)))) U)))))))).
